{
	"compatibility_date": "2026-06-12",
	"compatibility_flags": [
		"global_fetch_strictly_public",
		"nodejs_compat",
		"compatibility_flags"
	],
	"name": "wedding-invitation",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "wedding-session-kv-prod"
		}
	],
	"observability": {
		"enabled": true
	}
}