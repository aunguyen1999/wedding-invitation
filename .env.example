PUBLIC_FIREBASE_API_KEY=AIza...
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
PUBLIC_FIREBASE_PROJECT_ID=your-project
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
PUBLIC_FIREBASE_APP_ID=...

# Cloudflare R2 Storage (Optional, falls back to local assets if empty)
PUBLIC_R2_BASE_URL=https://media.auyenwedding.com

# Cloudflare R2 Private Credentials (Used only on server-side / build-time)
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET_NAME=your_r2_bucket_name

# Cloudflare Tunnel
TUNNEL_TOKEN=your_cloudflare_tunnel_token

# Vite Allowed Host
ALLOWED_HOST=.auyenwedding.com
