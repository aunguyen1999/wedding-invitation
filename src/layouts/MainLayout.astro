---
// src/layouts/MainLayout.astro
import '../styles/global.css';
import 'aos/dist/aos.css';

const { title = "Văn Âu & Kim Yến Wedding" } = Astro.props;
---

<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Trân trọng kính mời bạn đến dự lễ thành hôn của chúng tôi." />
    <meta property="og:image" content="/images/og-image.jpg" />
    <meta property="og:image:width" content="902" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content="https://www.auyenwedding.com" />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="Văn Âu & Kim Yến" />
  </head>
  <body class="bg-wedding-cream font-serif text-wedding-navy selection:bg-wedding-gold selection:text-wedding-navy">
    <slot />
    <script>
      import AOS from 'aos';
      
      AOS.init({
        duration: 1000,
        once: true,
        offset: 100,
        easing: 'ease-in-out-sine',
      });
    </script>
    <footer class="py-10 text-center opacity-50 text-sm">
      <p>© 2026 Crafted with ❤️ by Au Nguyen</p>
    </footer>
  </body>
</html>
