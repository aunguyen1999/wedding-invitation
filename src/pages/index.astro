---
import MainLayout from '@layouts/MainLayout.astro';
import Hero from '@components/Hero.astro';
import Biography from '@components/Biography.astro';
import Story from '@components/Story.astro';
import Timeline from '@components/Timeline.astro';
import Album from '@components/Album.astro';

import Cover from '@components/Cover.astro';
import Guestbook from '@components/Guestbook.astro';
import Program from '@components/Program.astro';
import MusicPlayer from '@components/MusicPlayer.astro';
import Countdown from '@components/Countdown.astro';
import Vendors from '@components/Vendors.astro';

import { 
  myWedding, 
  weddingData, 
  stories, 
  milestones, 
  brideProgram, 
  groomProgram,
  vendorsData
} from '@data/config';

// Cache HTML at the Cloudflare Edge level for 1 week, serve stale for 1 week
Astro.response.headers.set('Cache-Control', 'public, s-maxage=604800, stale-while-revalidate=604800');
---

<MainLayout>
  <Cover />
  <MusicPlayer />
	<Hero groomName={myWedding.groom}
		brideName={myWedding.bride}
		weddingDate={myWedding.date}
		heroImage={myWedding.mainPhoto}
		decorImage={myWedding.decorImage}
		slogan={myWedding.slogan}
	/>

  <Countdown targetDate="2026-07-19T09:00:00" />

	<Biography 
		role="Chú rể"
		name={weddingData.groom.name}
		description={weddingData.groom.desc}
		image={weddingData.groom.photo}
	/>

	<Biography 
		role="Cô dâu"
		name={weddingData.bride.name}
		description={weddingData.bride.desc}
		image={weddingData.bride.photo}
		reverse={true}
	/>

	{stories.map((s) => (
		<Story title={s.title} seed={s.seed} reverse={s.reverse}>
			<p>{s.content}</p>
		</Story>
	))}

	<Timeline events={milestones} />

	<Program 
		bride={brideProgram} 
		groom={groomProgram}
		brideDate="17 . 07 . 2026"
		groomDate="19 . 07 . 2026"
	/>

	<Album/>

  <Vendors vendors={vendorsData} />

  <Guestbook />

</MainLayout>