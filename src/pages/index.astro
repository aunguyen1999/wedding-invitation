---
import MainLayout from '@layouts/MainLayout.astro';
import Hero from '@components/Hero.astro';
import Biography from '@components/Biography.astro';
import Story from '@components/Story.astro';
import Timeline from '@components/Timeline.astro';
import Album from '@components/Album.astro';
import RSVP from '@components/RSVP.astro';

import groomBride from '@images/groom-bride.png';
import invitationDecor from '@images/invitation-decor.png';
import Cover from '@components/Cover.astro';
import Guestbook from '@components/Guestbook.astro';

const myWedding ={
  groom: "Văn Âu",
  bride: "Kim Yến",
  date: "19 . 07 . 2026",
  mainPhoto: groomBride,
  slogan: "Hành trình vạn dặm bắt đầu từ một bước chân chung đôi.",
  decorImage: invitationDecor
}

const weddingData = {
  groom: {
    name: "Văn Âu",
    desc: "Một chàng trai Drupal Developer yêu code và yêu vợ. Sở thích là build những thứ hay ho bằng Docker và ngắm nhìn hoàng hôn trên bãi biển.",
    photo: "https://picsum.photos/seed/man/800/1000",
    pet: "https://picsum.photos/seed/dog/400/400"
  },
  bride: {
    name: "Kim Yến",
    desc: "Cô gái Manual Tester luôn tỉ mỉ trong từng chi tiết. Thích du lịch, chụp ảnh và là mảnh ghép hoàn hảo nhất trong cuộc đời của Aun.",
    photo: "https://picsum.photos/seed/woman/800/1000",
    pet: "https://picsum.photos/seed/cat/400/400"
  }
};

const stories = [
  {
    title: "Lần đầu gặp gỡ - 2021",
    seed: "first-meet",
    content: "Chẳng phải tiếng sét ái tình, chỉ là một buổi chiều code bug mệt nhoài, mình vô tình đưa cho Thảo một cốc cafe. Ánh mắt ấy làm mình quên luôn lỗi 500 đang chờ fix.",
    reverse: false
  },
  {
    title: "Chuyến đi đầu tiên - 2022",
    seed: "travel-da-lat",
    content: "Đà Lạt năm ấy lạnh tê tái, nhưng cái nắm tay đầu tiên đã sưởi ấm tất cả. Chúng mình nhận ra, đi đâu không quan trọng, quan trọng là đi cùng ai.",
    reverse: true
  },
  {
    title: "Lời cầu hôn bất ngờ - 2025",
    seed: "proposal",
    content: "Giữa bãi biển lúc hoàng hôn, mình đã quỳ xuống và hỏi: 'Thảo có muốn cùng Anh fix bug cuộc đời này mãi mãi không?'. Và cô ấy đã say YES!",
    reverse: false
  }
];

const milestones = [
  {
    date: "12 / 2021",
    title: "Lần Đầu Gặp Gỡ",
    desc: "Tại buổi Workshop về Drupal, mình bị thu hút bởi cô gái Manual Tester đang chăm chú report bug."
  },
  {
    date: "02 / 2022",
    title: "Lời Tỏ Tình Ngọt Ngào",
    desc: "Đúng ngày Valentine, chúng mình chính thức trở thành một cặp dưới ánh đèn lung linh của Sài Gòn."
  },
  {
    date: "05 / 2024",
    title: "Chuyến Du Lịch Xa Đầu Tiên",
    desc: "Cùng nhau chinh phục đỉnh Fansipan, hứa với nhau sẽ cùng leo qua mọi 'ngọn núi' của cuộc đời."
  },
  {
    date: "19 / 07 / 2026",
    title: "Lễ Thành Hôn",
    desc: "Ngày mà chúng mình chính thức về chung một nhà, bắt đầu một chương mới đầy hứa hẹn."
  }
];

const albumPhotos = Array.from({ length: 20 }, (_, i) => `photo-seed-${i}`);
---

<MainLayout>
  <Cover />
	<Hero groomName={myWedding.groom}
		brideName={myWedding.bride}
		weddingDate={myWedding.date}
		heroImage={myWedding.mainPhoto}
		decorImage={myWedding.decorImage}
		slogan={myWedding.slogan}
	/>

	<Biography 
		role="Chú rể"
		name={weddingData.groom.name}
		description={weddingData.groom.desc}
		image={weddingData.groom.photo}
		subImage={weddingData.groom.pet}
	/>

	<Biography 
		role="Cô dâu"
		name={weddingData.bride.name}
		description={weddingData.bride.desc}
		image={weddingData.bride.photo}
		subImage={weddingData.bride.pet}
		reverse={true}
	/>

	{stories.map((s) => (
		<Story title={s.title} seed={s.seed} reverse={s.reverse}>
			<p>{s.content}</p>
		</Story>
	))}

	<Timeline events={milestones} />

	<Album seeds={albumPhotos} />

  <Guestbook />
  
</MainLayout>