---
// src/components/Story.astro
interface Props {
  title?: string;
  image?: string;
  seed?: string;
  reverse?: boolean; // Thêm prop này để đảo chiều
}

const { 
  title, 
  image, 
  seed = "love-story",
  reverse = false 
} = Astro.props;

const finalImage = image || `https://picsum.photos/seed/${seed}/1200/800`;
---

<section class={`py-20 ${reverse ? 'bg-wedding-navy text-wedding-cream' : 'bg-wedding-cream text-wedding-navy'} relative overflow-hidden transition-colors duration-500`} data-aos={reverse ? "fade-left" : "fade-right"}>
  <div class="container mx-auto px-6 max-w-6xl relative z-10">
    
    <div class={`flex flex-col ${reverse ? 'md:flex-row-reverse' : 'md:flex-row'} items-center gap-12 md:gap-20`}>
      
      <div class="flex-1 relative group w-full">
        <div class="overflow-hidden rounded-lg shadow-2xl">
          <img 
            src={finalImage} 
            alt="Story Moment" 
            class="w-full h-[400px] object-cover transition-transform duration-[2000ms] group-hover:scale-110"
          />
        </div>
        <div class={`absolute -inset-4 border-2 border-wedding-gold/30 -z-10 ${reverse ? '-translate-x-3' : 'translate-x-3'} translate-y-3 rounded-lg`}></div>
      </div>

      <div class="flex-1 space-y-6">
        {title && (
          <h3 class="text-3xl md:text-4xl font-serif tracking-wide border-b border-wedding-gold/50 inline-block pb-2 mb-4">
            {title}
          </h3>
        )}
        
        <div class="font-serif text-lg leading-relaxed italic opacity-90 space-y-4">
          <slot />
        </div>
        
        <div class="pt-4 flex items-center gap-4">
            <div class="h-[1px] w-12 bg-wedding-gold"></div>
            <span class="font-philosopher text-xs uppercase tracking-widest text-wedding-gold">Mãi mãi bên nhau</span>
        </div>
      </div>
    </div>
  </div>
</section>