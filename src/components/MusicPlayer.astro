---
import '@styles/music-player.css';
---

<div id="wedding-music-player" class="music-player-container is-paused">
  <div id="vinyl-toggle-wrapper" class="turntable-base">
    <div class="vinyl-disc">
      <div class="vinyl-center"></div>
    </div>
    <div class="tonearm-pivot">
      <div class="tonearm-arm"></div>
    </div>
  </div>

  <div class="track-info">
    <span id="music-track-title" class="track-title">Loading...</span>
    <span id="music-track-artist" class="track-artist">Loading...</span>
  </div>

  <div class="music-controls">
    <button id="music-play-pause-btn" class="control-btn" aria-label="Phát hoặc Tạm dừng">
      <svg class="play-svg" viewBox="0 0 24 24">
        <path d="M8 5v14l11-7z" />
      </svg>
      <svg class="pause-svg" viewBox="0 0 24 24" style="display: none;">
        <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
      </svg>
    </button>
    <button id="music-next-btn" class="control-btn" aria-label="Bài tiếp theo">
      <svg class="next-svg" viewBox="0 0 24 24">
        <path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z" />
      </svg>
    </button>
  </div>
</div>

<script>
  import { initMusicPlayer } from '@scripts/music-player.js';
  initMusicPlayer();
</script>
