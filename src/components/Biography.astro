---
// src/components/Biography.astro
interface Props {
  name: string;
  description: string;
  image: string;
  subImage?: string;
  reverse?: boolean;
  role: "Chú rể" | "Cô dâu";
}

const { 
  name, 
  description, 
  image, 
  subImage, 
  reverse = false, 
  role 
} = Astro.props;
---

<section class="py-20 bg-wedding-cream overflow-hidden">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class={`flex flex-col ${reverse ? 'md:flex-row-reverse' : 'md:flex-row'} items-center gap-12 md:gap-24`}>
      
      <div class="flex-1 relative w-full group">
        <div class="relative z-10 border-8 border-white shadow-xl overflow-hidden aspect-[4/5] rounded-lg">
          <img 
            src={image} 
            alt={name} 
            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
          />
        </div>
        
        {subImage && (
          <div class={`absolute -bottom-8 ${reverse ? '-left-8' : '-right-8'} z-20 w-32 h-32 md:w-48 md:h-48 border-8 border-wedding-cream overflow-hidden rounded-full shadow-lg`}>
            <img src={subImage} alt="pet" class="w-full h-full object-cover" />
          </div>
        )}
        
        <div class={`absolute -inset-4 bg-wedding-gold/30 -z-10 rounded-lg ${reverse ? '-translate-x-6' : 'translate-x-6'} translate-y-6`}></div>
      </div>

      <div class="flex-1 text-center md:text-left space-y-6">
        <div class="space-y-2">
          <span class="font-philosopher uppercase tracking-[0.2em] text-wedding-gold text-sm font-bold">
            {role}
          </span>
          <h2 class="text-5xl md:text-6xl font-serif text-wedding-navy leading-tight">
            {name}
          </h2>
        </div>
        
        <div class="w-20 h-[2px] bg-wedding-gold mx-auto md:mx-0"></div>
        
        <p class="text-lg leading-relaxed text-wedding-navy/80 font-serif whitespace-pre-line">
          {description}
        </p>
        
        <div class="pt-4">
            <button class="px-8 py-3 border border-wedding-navy text-wedding-navy hover:bg-wedding-navy hover:text-wedding-cream transition-all duration-300 font-philosopher uppercase tracking-widest text-xs">
                Xem thêm
            </button>
        </div>
      </div>

    </div>
  </div>
</section>
