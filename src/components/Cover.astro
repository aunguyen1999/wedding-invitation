---
import {Image} from 'astro:assets';
import { getR2ImageUrl } from '../utils/r2';
import '@styles/cover.css';

// Request the pre-optimized WebP from R2 — bypass Astro <Image> processing entirely
const coverImg = getR2ImageUrl('hero-portrait.webp');
---

<div id="wedding-cover" class="wedding-cover-container">
  <div class="split-panel left-panel">
    <div class="cover-bg-wrap">
      {coverImg && (
        <Image
          src={coverImg}
          alt=""
          class="cover-bg-image"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          aria-hidden="true"
          inferSize={true}
        />
      )}
      <div class="cover-overlay"></div>
    </div>
    <div class="envelope-half envelope-left"></div>
  </div>

  <div class="split-panel right-panel">
    <div class="cover-bg-wrap">
      {coverImg && (
        <Image
          src={coverImg}
          alt=""
          class="cover-bg-image"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          aria-hidden="true"
          inferSize={true}
        />
      )}
      <div class="cover-overlay"></div>
    </div>
    <div class="envelope-half envelope-right"></div>
  </div>

  <div class="cover-instruction" id="cover-instruction">
    <h4 class="text-wedding-gold font-philosopher uppercase tracking-[0.4em] text-xs md:text-sm mb-2">Save The Date</h4>
    <h1 class="text-4xl md:text-6xl font-serif text-wedding-cream mb-4">Âu & Yến</h1>
    <div id="cover-guest-wrapper" class="cover-guest-wrapper">
      <div class="cover-guest-divider"></div>
      <p class="cover-guest-label">Kính mời</p>
      <p class="cover-guest-name" id="cover-guest-name"></p>
    </div>
    <div class="tap-hint">Bấm để mở thiệp cưới</div>
  </div>

  <div class="envelope-seal" id="envelope-seal">
    <div class="seal-inner">❤</div>
  </div>
</div>

<script>
  import { initCover } from '@scripts/cover.js';
  initCover();
</script>