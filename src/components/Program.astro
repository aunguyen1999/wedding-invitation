---
import '@styles/program.css';

interface ProgramEvent {
  time: string;
  title: string;
  desc: string;
  icon: 'welcome' | 'ceremony' | 'feast' | 'farewell' | string;
  location?: string;
  mapLink?: string;
}

interface Props {
  bride: ProgramEvent[];
  groom: ProgramEvent[];
  brideDate?: string;
  groomDate?: string;
}

const { 
  bride = [], 
  groom = [],
  brideDate,
  groomDate
} = Astro.props;
---

<section class="py-24 program-section" id="program">
  <div class="container mx-auto px-6 max-w-6xl">
    
    <div class="text-center mb-16 space-y-4" data-aos="fade-up">
      <h2 class="text-4xl md:text-5xl font-serif tracking-[0.2em] uppercase text-wedding-gold">Chương Trình Hôn Lễ</h2>
      <div class="w-20 h-[1px] bg-wedding-gold mx-auto"></div>
    </div>

    <div class="program-sections-wrapper">
      <div class="program-column">
        <div class="text-center mb-6" data-aos="fade-up">
          <h3 class="text-2xl md:text-3xl font-serif text-wedding-gold tracking-widest uppercase">Lễ Vu Quy</h3>
          {brideDate && (
            <p class="text-wedding-gold font-philosopher tracking-widest text-sm mt-2">{brideDate}</p>
          )}
        </div>
        
        <div class="program-tree-container">
          <div class="program-tree-line"></div>
          {bride.map((item, index) => (
            <div class="program-tree-item" data-aos="fade-right" data-aos-delay={index * 100}>
              <div class="program-tree-time">{item.time}</div>
              <div class="program-tree-node">
                <div class="program-tree-icon-wrap">
                  {item.icon === 'welcome' && (
                    <svg class="program-icon-svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22V12m0 0l-7-7h14l-7 7z" />
                      <path d="M12 12H5M12 12h7" />
                      <path d="M9 22h6" />
                      <circle cx="12" cy="7" r="1.5" fill="currentColor" />
                    </svg>
                  )}
                  {item.icon === 'ceremony' && (
                    <svg class="program-icon-svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="8" cy="12" r="5" />
                      <circle cx="16" cy="12" r="5" />
                      <path d="M12 8a3 3 0 0 1 0 8" />
                    </svg>
                  )}
                  {item.icon === 'feast' && (
                    <svg class="program-icon-svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="9" />
                      <path d="M12 3v18" />
                      <path d="M3 12h18" />
                      <path d="M8 8l8 8" />
                      <path d="M16 8l-8 8" />
                    </svg>
                  )}
                  {item.icon === 'farewell' && (
                    <svg class="program-icon-svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                      <circle cx="12" cy="13" r="4" />
                    </svg>
                  )}
                </div>
              </div>
              <div class="program-tree-content">
                <div class="program-tree-title">{item.title}</div>
                {item.location && (
                  <div class="program-tree-location">
                    <span>{item.location}</span>
                    {item.mapLink && (
                      <a href={item.mapLink} target="_blank" class="program-tree-map-link">
                        <svg class="location-icon-mini" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                          <circle cx="12" cy="10" r="3" />
                        </svg>
                        Bản đồ
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="program-vertical-divider"></div>

      <div class="program-column">
        <div class="text-center mb-6" data-aos="fade-up">
          <h3 class="text-2xl md:text-3xl font-serif text-wedding-gold tracking-widest uppercase">Lễ Thành Hôn</h3>
          {groomDate && (
            <p class="text-wedding-gold font-philosopher tracking-widest text-sm mt-2">{groomDate}</p>
          )}
        </div>
        
        <div class="program-tree-container">
          <div class="program-tree-line"></div>
          {groom.map((item, index) => (
            <div class="program-tree-item" data-aos="fade-left" data-aos-delay={index * 100}>
              <div class="program-tree-time">{item.time}</div>
              <div class="program-tree-node">
                <div class="program-tree-icon-wrap">
                  {item.icon === 'welcome' && (
                    <svg class="program-icon-svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22V12m0 0l-7-7h14l-7 7z" />
                      <path d="M12 12H5M12 12h7" />
                      <path d="M9 22h6" />
                      <circle cx="12" cy="7" r="1.5" fill="currentColor" />
                    </svg>
                  )}
                  {item.icon === 'ceremony' && (
                    <svg class="program-icon-svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="8" cy="12" r="5" />
                      <circle cx="16" cy="12" r="5" />
                      <path d="M12 8a3 3 0 0 1 0 8" />
                    </svg>
                  )}
                  {item.icon === 'feast' && (
                    <svg class="program-icon-svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="9" />
                      <path d="M12 3v18" />
                      <path d="M3 12h18" />
                      <path d="M8 8l8 8" />
                      <path d="M16 8l-8 8" />
                    </svg>
                  )}
                  {item.icon === 'farewell' && (
                    <svg class="program-icon-svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                      <circle cx="12" cy="13" r="4" />
                    </svg>
                  )}
                </div>
              </div>
              <div class="program-tree-content">
                <div class="program-tree-title">{item.title}</div>
                {item.location && (
                  <div class="program-tree-location">
                    <span>{item.location}</span>
                    {item.mapLink && (
                      <a href={item.mapLink} target="_blank" class="program-tree-map-link">
                        <svg class="location-icon-mini" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                          <circle cx="12" cy="10" r="3" />
                        </svg>
                        Bản đồ
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
