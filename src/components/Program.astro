---
import '@styles/program.css';

interface ProgramEvent {
  time: string;
  title: string;
  desc: string;
  icon: 'welcome' | 'ceremony' | 'feast' | 'farewell' | string;
  location?: string;
  mapLink?: string;
}

interface Props {
  bride: ProgramEvent[];
  groom: ProgramEvent[];
  brideDate?: string;
  groomDate?: string;
}

const { 
  bride = [], 
  groom = [],
  brideDate,
  groomDate
} = Astro.props;
const icons = {
  feast: `<svg class="program-icon-svg" viewBox="-0.89 0 122.88 122.88" fill="currentColor"><path class="st0" d="M56.6,42.23c-10.57-9.69-27.14-5.26-41.16-6.82c2.29-7.28,5.35-15.21,8.72-23.59 c2.98-7.42,3.01-7.41,8.55-6.22c1.02,0.22,2.18,0.47,3.35,0.7l18.46,3.64c0.93,0.26,1.62,0.67,2.09,1.22 c0.48,0.56,0.79,1.3,0.94,2.23c-0.09,2.7-0.13,5.69-0.17,8.81C57.3,28.52,57.21,35.45,56.6,42.23L56.6,42.23z M84.64,120.9 c-1.81,0.35-3.56-0.84-3.91-2.65c-0.35-1.81,0.84-3.56,2.65-3.91l14.07-2.72l-6.01-29.38c-2.05,0.2-4.02,0.17-5.89-0.09 c-4.12-0.57-7.76-2.22-10.93-4.92c-8.79-7.47-12.21-19.66-13.59-32.38c-1.38,12.71-4.8,24.9-13.59,32.38 c-3.18,2.7-6.82,4.35-10.93,4.92c-1.87,0.26-3.83,0.29-5.89,0.09l-6.42,31.41l13.52,2.62c1.81,0.35,3,2.1,2.65,3.91 c-0.35,1.81-2.1,3-3.91,2.65l-33.75-6.53c-1.81-0.35-3-2.1-2.65-3.91c0.35-1.81,2.1-3,3.91-2.65l13.67,2.64l6.44-31.47 c-0.24-0.07-0.48-0.15-0.73-0.23c-0.04-0.01-0.08-0.02-0.12-0.04C10.02,76.34,5.77,66.96,6.67,54.09 c0.84-12.06,6.39-27.18,13.15-44.01C24.28-1,24.32-0.99,33.68,1.02c0.91,0.2,1.95,0.42,3.27,0.68l18.5,3.65l0,0 c0.05,0.01,0.1,0.02,0.15,0.03c1.93,0.51,3.43,1.43,4.55,2.73c0.33,0.39,0.62,0.8,0.88,1.24c0.25-0.44,0.55-0.86,0.88-1.24 c1.12-1.3,2.63-2.22,4.55-2.73c0.05-0.01,0.1-0.02,0.15-0.03l0,0l18.5-3.65c1.32-0.26,2.36-0.48,3.27-0.68 c9.36-2.01,9.4-2.02,13.85,9.06c6.77,16.83,12.31,31.95,13.15,44.01c0.9,12.86-3.35,22.25-16.56,26.55 c-0.04,0.01-0.08,0.02-0.12,0.04c-0.24,0.08-0.49,0.15-0.73,0.23l6.02,29.45l13.13-2.54c1.81-0.35,3.56,0.84,3.91,2.65 c0.35,1.81-0.84,3.56-2.65,3.91L84.64,120.9L84.64,120.9z M74.1,59.53c-0.27-0.69,0.07-1.46,0.76-1.73s1.46,0.07,1.73,0.76 c1.71,4.35,4.08,7.55,7.02,9.75c2.93,2.18,6.46,3.39,10.51,3.74c0.74,0.06,1.28,0.71,1.22,1.45c-0.06,0.74-0.71,1.28-1.45,1.22 c-4.54-0.4-8.53-1.77-11.88-4.26C78.68,67.96,76.01,64.37,74.1,59.53L74.1,59.53z M65.56,43.33c15.19-6.85,30.94-14.24,39.03-13.99 c-1.95-5.55-4.24-11.42-6.69-17.52c-2.98-7.42-3.01-7.41-8.55-6.22c-1.02,0.22-2.18,0.47-3.35,0.7L67.55,9.94 c-0.93,0.26-1.62,0.67-2.09,1.22c-0.48,0.56-0.79,1.3-0.94,2.23c0.09,2.7,0.13,5.69,0.17,8.81C64.76,28.86,64.85,36.2,65.56,43.33 L65.56,43.33z M48.68,53.5c0.1-0.73,0.78-1.24,1.51-1.13c0.73,0.1,1.24,0.78,1.13,1.51c-0.75,5.14-2.52,9.25-5.21,12.44 c-2.69,3.2-6.26,5.45-10.58,6.87c-0.7,0.23-1.46-0.15-1.69-0.85c-0.23-0.7,0.15-1.46,0.85-1.69c3.87-1.27,7.03-3.25,9.38-6.05 C46.44,61.8,48,58.14,48.68,53.5L48.68,53.5z"/></svg>`,
  ceremony: `<svg class="program-icon-svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M4 3.17a2 2 0 0 1 2.83 0L7 3.34l.17-.17a2 2 0 1 1 2.83 2.83l-3 3-3-3a2 2 0 0 1 0-2.83z" /><circle cx="9" cy="15" r="5" /><circle cx="15" cy="11" r="5" /></svg>`,
  welcome: `<svg class="program-icon-svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9" /><path d="M12 3v18" /><path d="M3 12h18" /><path d="M8 8l8 8" /><path d="M16 8l-8 8" /></svg>`,
};

const sections = [
  { id: 'bride', title: 'Lễ Vu Quy', date: brideDate, events: bride, animationDir: 'fade-right' },
  { id: 'groom', title: 'Lễ Thành Hôn', date: groomDate, events: groom, animationDir: 'fade-left' }
];
---

<section class="py-24 program-section" id="program">
  <div class="container mx-auto px-6 max-w-6xl">
    
    <div class="text-center mb-16 space-y-4" data-aos="fade-up">
      <h2 class="text-4xl md:text-5xl font-serif tracking-[0.2em] uppercase text-wedding-gold">Chương Trình Hôn Lễ</h2>
      <div class="w-20 h-[1px] bg-wedding-gold mx-auto"></div>
    </div>

    <div class="program-sections-wrapper">
      {sections.map((section, sectionIdx) => (
        <>
          <div class="program-column">
            <div class="text-center mb-6" data-aos="fade-up">
              <h3 class="text-2xl md:text-3xl font-serif text-wedding-gold tracking-widest uppercase">{section.title}</h3>
              {section.date && (
                <p class="text-wedding-gold font-philosopher tracking-widest text-sm mt-2">{section.date}</p>
              )}
            </div>
            
            <div class="program-tree-container">
              <div class="program-tree-line"></div>
              {section.events.map((item, index) => (
                <div class={`program-tree-item ${index % 2 !== 0 ? 'program-tree-item--reverse' : ''}`} data-aos={section.animationDir} data-aos-delay={index * 100}>
                  <div class="program-tree-time">{item.time}</div>
                  <div class="program-tree-node">
                    <div class="program-tree-icon-wrap">
                      <Fragment set:html={icons[item.icon as keyof typeof icons] || icons.welcome} />
                    </div>
                  </div>
                  <div class="program-tree-content">
                    <div class="program-tree-title">{item.title}</div>
                    {item.location && (
                      <div class="program-tree-location">
                        <span>{item.location}</span>
                        {item.mapLink && (
                          <a href={item.mapLink} target="_blank" class="program-tree-map-link">
                            <svg class="location-icon-mini" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                              <circle cx="12" cy="10" r="3" />
                            </svg>
                            Bản đồ
                          </a>
                        )}
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
          {sectionIdx === 0 && <div class="program-vertical-divider"></div>}
        </>
      ))}
    </div>
  </div>
</section>
