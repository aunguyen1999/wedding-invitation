---
// src/components/RSVP.astro
import { Image } from 'astro:assets';
import decorFlower from '@images/invitation-decor.png';
---

<section class="py-24 bg-wedding-navy text-wedding-cream relative overflow-hidden" id="rsvp-section">
  <div class="absolute -top-20 -right-20 w-80 opacity-10 pointer-events-none invert rotate-12">
    <Image src={decorFlower} alt="decor" quality="low" />
  </div>

  <div class="container mx-auto px-6 max-w-3xl relative z-10" data-aos="zoom-in">
    
    <div class="text-center mb-12 space-y-4">
      <h2 class="text-4xl md:text-5xl font-serif tracking-[0.2em] uppercase text-wedding-gold">Xác Nhận Tham Dự</h2>
      <p class="font-philosopher italic opacity-80 text-lg">Sự hiện diện của bạn là niềm hạnh phúc của chúng tôi</p>
      <div class="w-20 h-[1px] bg-wedding-gold mx-auto"></div>
    </div>

    <div id="rsvp-form-container">
      <form 
        id="rsvp-form"
        action="https://formspree.io/f/xqegwlwd" 
        method="POST" 
        class="space-y-8 font-serif"
      >
        <div class="flex flex-col md:flex-row justify-center items-center gap-8 py-4 border-y border-wedding-gold/10">
          <label class="flex items-center gap-3 cursor-pointer group">
            <input type="radio" name="status" value="Sẽ tham dự" checked class="w-5 h-5 accent-wedding-gold cursor-pointer" />
            <span class="text-lg font-philosopher uppercase tracking-widest group-hover:text-wedding-gold transition-colors">Sẽ tham dự</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer group">
            <input type="radio" name="status" value="Rất tiếc không thể đến" class="w-5 h-5 accent-wedding-gold cursor-pointer" />
            <span class="text-lg font-philosopher uppercase tracking-widest group-hover:text-wedding-gold transition-colors opacity-60">Rất tiếc không thể đến</span>
          </label>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="group space-y-2">
            <label class="text-xs uppercase tracking-[0.2em] text-wedding-gold/70 group-focus-within:text-wedding-gold transition-colors">Họ và Tên</label>
            <input type="text" name="name" required class="w-full bg-transparent border-b border-wedding-gold/30 py-3 focus:border-wedding-gold outline-none transition-all placeholder:text-wedding-cream/20" placeholder="Ví dụ: Nguyễn Văn Âu" />
          </div>
          
          <div class="group space-y-2">
            <label class="text-xs uppercase tracking-[0.2em] text-wedding-gold/70">Số điện thoại</label>
            <input type="tel" name="phone" class="w-full bg-transparent border-b border-wedding-gold/30 py-3 outline-none focus:border-wedding-gold transition-all placeholder:text-wedding-cream/20" placeholder="090..." />
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="group space-y-2">
            <label class="text-xs uppercase tracking-[0.2em] text-wedding-gold/70">Bạn là khách của...</label>
            <div class="relative">
              <select name="guest_of" class="w-full bg-transparent border-b border-wedding-gold/30 py-3 outline-none focus:border-wedding-gold cursor-pointer appearance-none transition-all">
                <option value="groom" class="bg-wedding-navy">Nhà Trai (Chú rể Âu)</option>
                <option value="bride" class="bg-wedding-navy">Nhà Gái (Cô dâu Yến)</option>
              </select>
              <span class="absolute right-0 bottom-3 pointer-events-none opacity-50 text-[10px]">▼</span>
            </div>
          </div>

          <div class="group space-y-2" id="guests-container">
            <label class="text-xs uppercase tracking-[0.2em] text-wedding-gold/70">Số người tham dự</label>
            <input type="number" name="guests" min="1" max="10" value="1" class="w-full bg-transparent border-b border-wedding-gold/30 py-3 outline-none focus:border-wedding-gold transition-all" />
          </div>
        </div>

        <div class="group space-y-2">
          <label class="text-xs uppercase tracking-[0.2em] text-wedding-gold/70">Lời chúc dành cho đôi bạn</label>
          <textarea name="message" rows="3" class="w-full bg-transparent border-b border-wedding-gold/30 py-3 outline-none focus:border-wedding-gold transition-all placeholder:text-wedding-cream/20 resize-none" placeholder="Gửi gắm lời chúc ngọt ngào nhất..."></textarea>
        </div>

        <div class="text-center pt-10">
          <button type="submit" id="submit-btn" class="relative overflow-hidden group bg-wedding-gold text-wedding-navy px-16 py-5 font-philosopher uppercase tracking-[0.3em] font-bold transition-all duration-500 hover:shadow-[0_0_30px_rgba(237,208,189,0.4)] active:scale-95">
            <span class="relative z-10 btn-text text-base">Gửi xác nhận</span>
            <div class="absolute inset-0 bg-white scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-500 opacity-20"></div>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const radioButtons = document.querySelectorAll('input[name="status"]');
  const guestsContainer = document.getElementById('guests-container');

  radioButtons.forEach(radio => {
    radio.addEventListener('change', (e) => {
      const value = (e.target as HTMLInputElement).value;
      if (guestsContainer) {
        guestsContainer.style.opacity = value === "Sẽ tham dự" ? "1" : "0.3";
        guestsContainer.style.pointerEvents = value === "Sẽ tham dự" ? "auto" : "none";
      }
    });
  });

  // 2. Logic gửi Form và Overwrite Title
  const rsvpForm = document.getElementById('rsvp-form') as HTMLFormElement;
  const container = document.getElementById('rsvp-form-container');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = submitBtn?.querySelector('.btn-text');

  rsvpForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (btnText) btnText.textContent = "Đang gửi...";
    if (submitBtn) (submitBtn as HTMLButtonElement).disabled = true;

    const rawData = new FormData(rsvpForm);
    
    const mappedData = {
      "Trạng thái tham dự": rawData.get('status'),
      "Họ và Tên": rawData.get('name'),
      "Số điện thoại": rawData.get('phone'),
      "Khách của ai": rawData.get('side') === 'groom' ? 'Nhà Trai (Âu)' : 'Nhà Gái (Yến)',
      "Số người đi cùng": rawData.get('guests'),
      "Lời chúc": rawData.get('message')
    };

    try {
      const response = await fetch(rsvpForm.action, {
        method: rsvpForm.method,
        body: JSON.stringify(mappedData),
        headers: { 
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        }
      });

      if (response.ok) {
        if (container) {
          container.innerHTML = `
            <div class="py-16 text-center space-y-6 animate-fade-in">
              <div class="text-6xl animate-bounce">❤️</div>
              <h3 class="text-3xl font-serif text-wedding-gold uppercase tracking-widest">Cảm ơn bạn!</h3>
              <p class="text-lg font-philosopher italic opacity-90 leading-relaxed">
                Phản hồi của bạn đã được gửi đến Âu & Yến.<br/>
                Sự hiện diện của bạn chính là món quà ý nghĩa nhất.
              </p>
            </div>
          `;
        }
      } else { throw new Error(); }
    } catch (error) {
      alert("Lỗi rồi babe ơi! Thử lại giùm anh nhé.");
      if (btnText) btnText.textContent = "Gửi xác nhận";
      if (submitBtn) (submitBtn as HTMLButtonElement).disabled = false;
    }
  });
</script>
