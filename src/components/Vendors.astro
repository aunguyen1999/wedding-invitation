---
import '@styles/vendors.css';
import { Image } from 'astro:assets';

interface Props {
  vendors: Array<{
    role: string;
    name: string;
    logo: any;
    url: string;
  }>;
}

const { vendors } = Astro.props;
---

<section class="vendors-section" id="vendors">
  <div class="container mx-auto px-6 max-w-5xl" data-aos="fade-up">
    <div class="text-center mb-8">
      <h2 class="text-3xl font-sans text-wedding-navy tracking-[0.3em] uppercase">Đơn Vị Đồng Hành</h2>
    </div>
    
    <div class="brand-marquee-container">
      <div class="brand-marquee-track">
        {vendors.map(vendor => {
          const Element = vendor.url ? 'a' : 'div';
          return (
          <Element 
            href={vendor.url || undefined}
            target={vendor.url?.startsWith('http') ? '_blank' : undefined}
            rel={vendor.url?.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="brand-item"
          >

            <div class="brand-placeholder-wrapper flex flex-col items-center justify-center gap-3">
                <Image src={vendor.logo} alt={vendor.name} class="brand-logo" />
                <div class="flex flex-col items-center justify-center">
                  <span class="brand-name">{vendor.name}</span>
                  <span class="brand-role">{vendor.role}</span>
                </div>
              </div>
          </Element>
        )})}
        {/* Duplicate items to create infinite scroll effect */}
        {vendors.map(vendor => {
          const Element = vendor.url ? 'a' : 'div';
          return (
          <Element 
            href={vendor.url || undefined}
            target={vendor.url?.startsWith('http') ? '_blank' : undefined}
            rel={vendor.url?.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="brand-item"
            aria-hidden="true"
          >
            <div class="brand-placeholder-wrapper flex flex-col items-center justify-center gap-3">
              <Image src={vendor.logo} alt={vendor.name} class="brand-logo" />
              <div class="flex flex-col items-center justify-center">
                <span class="brand-name">{vendor.name}</span>
                <span class="brand-role">{vendor.role}</span>
              </div>
            </div>
          </Element>
        )})}
      </div>
    </div>
  </div>
</section>
